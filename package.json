{
  "name": "timeago.js",
  "officialName": "timeago.js",
  "version": "4.0.2",
  "summary": "timeago.js is a nano library (less than 2kb) used to format datetime with `*** time ago` statement. eg: '3 hours ago'.",
  "description": "timeago.js is a nano library (less than 2kb) used to format datetime with `*** time ago` statement. eg: '3 hours ago'. i18n supported.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "unpkg": "dist/timeago.umd.js",
  "browser": "dist/timeago.umd.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint src __tests__",
    "lint-staged": "lint-staged",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "rimraf dist && vite build && vite build --config vite.full.config.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "rimraf": "^5.0.10",
    "terser": "^5.48.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "author": {
    "name": "hustcc",
    "url": "https://timeago.org"
  },
  "license": "MIT",
  "keywords": [
    "timeago",
    "datetime",
    "*** time ago",
    "date",
    "javascript timeago"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hustcc/timeago.js"
  },
  "bugs": {
    "url": "https://github.com/hustcc/timeago.js/issues"
  }
}
